{
  "name": "obsidian-excel-html-paste",
  "version": "0.1.0",
  "description": "Paste Excel HTML clipboard data into Obsidian as managed image/html assets.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "build:helper": "cargo build --manifest-path helper/Cargo.toml --release",
    "build:helper:win64": "cargo build --manifest-path helper/Cargo.toml --release --target x86_64-pc-windows-msvc"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "excel",
    "clipboard",
    "html"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.2",
    "obsidian": "^1.5.12",
    "tslib": "^2.6.2",
    "typescript": "^5.4.2"
  }
}
